.DS_Store
*.swp
node_modules/

# VSDD infrastructure — factory worktree lives on factory-artifacts orphan branch
.factory/
# Reference codebases — cloned for brownfield-ingest analysis, never committed to main
.reference/
# Subagent isolation worktrees — created by Agent(isolation: "worktree") and
# left behind when the worker process is still attached. They embed a git
# repo, which `git add -A` would otherwise try to stage as a submodule.
.claude/worktrees/

# factory-obs generated override file (multi-factory compose layer).
# Regenerated per-machine from ~/.config/vsdd-factory/watched-factories.
plugins/vsdd-factory/tools/observability/docker-compose.override.yml

# Rust workspace build outputs. Cargo.lock is checked in (binary-producing
# workspace) so per-developer reproducibility holds; per-platform target/
# directories are not.
target/
*.profraw

# Python bytecode from CI helper scripts (e.g. scripts/check-platforms-drift.py).
__pycache__/
*.pyc

# v1.0 activation skill copies the right hooks.json.<platform> variant
# into hooks.json after install — that copy is per-machine and must not
# be committed. The 5 hooks.json.<platform> files (CI-generated from
# hooks.json.template by scripts/generate-hooks-json.sh) ARE committed.
plugins/vsdd-factory/hooks/hooks.json
