#!/bin/bash
# research-cache — SHA-keyed disk cache for research-agent queries.
#
# Ports dark-factory's research-cache.ts runtime extension. Callers key
# queries by content hash; the cache stores results under
# `.factory/research-cache/<sha>.json` and optionally expires them.
#
# Usage:
#   research-cache get <key>              # prints cached JSON to stdout, exit 1 if miss
#   research-cache put <key> < result     # stores stdin as cached JSON
#   research-cache has <key>              # exit 0 if present, 1 if miss
#   research-cache key <query-text>       # emits the cache key for a query string
#   research-cache clear                  # delete all cached entries
#   research-cache stats                  # entry count and total size
#
# Keys are SHA-256 of the query text. `key` normalizes by trimming whitespace.

set -euo pipefail

CACHE_DIR="${VSDD_RESEARCH_CACHE_DIR:-.factory/research-cache}"

die() { echo "research-cache: $*" >&2; exit 1; }

if ! command -v shasum &>/dev/null && ! command -v sha256sum &>/dev/null; then
  die "shasum or sha256sum is required"
fi

_sha() {
  if command -v sha256sum &>/dev/null; then
    sha256sum | awk '{print $1}'
  else
    shasum -a 256 | awk '{print $1}'
  fi
}

_key_for() {
  printf '%s' "$1" | tr -s '[:space:]' ' ' | sed 's/^ //;s/ $//' | _sha
}

[[ $# -ge 1 ]] || die "usage: research-cache <get|put|has|key|clear|stats> [args]"
CMD="$1"; shift || true

case "$CMD" in
  key)
    [[ $# -ge 1 ]] || die "usage: research-cache key <query>"
    _key_for "$1"
    ;;
  get)
    [[ $# -ge 1 ]] || die "usage: research-cache get <key>"
    f="$CACHE_DIR/$1.json"
    [[ -f "$f" ]] || exit 1
    cat "$f"
    ;;
  has)
    [[ $# -ge 1 ]] || die "usage: research-cache has <key>"
    [[ -f "$CACHE_DIR/$1.json" ]] && exit 0 || exit 1
    ;;
  put)
    [[ $# -ge 1 ]] || die "usage: research-cache put <key> < result"
    mkdir -p "$CACHE_DIR"
    cat > "$CACHE_DIR/$1.json"
    ;;
  clear)
    if [[ -d "$CACHE_DIR" ]]; then
      rm -rf "$CACHE_DIR"/*.json 2>/dev/null || true  # STDERR-EXEMPT: rm may warn on empty glob
      echo "cleared: $CACHE_DIR"
    fi
    ;;
  stats)
    if [[ ! -d "$CACHE_DIR" ]]; then
      echo "entries=0 bytes=0 dir=$CACHE_DIR (not created)"
      exit 0
    fi
    count=$(find "$CACHE_DIR" -name '*.json' -type f | wc -l | tr -d ' ')
    bytes=$(du -sk "$CACHE_DIR" 2>/dev/null | awk '{print $1*1024}' || echo 0)  # STDERR-EXEMPT: du may warn on perms
    echo "entries=$count bytes=$bytes dir=$CACHE_DIR"
    ;;
  *)
    die "unknown command: $CMD"
    ;;
esac
