#!/bin/bash
# compute-input-hash â€” compute MD5 hash of an artifact's input files.
#
# Usage:
#   compute-input-hash <artifact-file>              # print the hash
#   compute-input-hash <artifact-file> --update     # compute and write into frontmatter
#   compute-input-hash <artifact-file> --check      # compare stored vs computed
#   compute-input-hash --scan <root-dir>            # walk dir, report drift
#   compute-input-hash --scan <root-dir> --update   # walk dir + update stale hashes
#
# Reads the `inputs:` frontmatter field, resolves file paths relative to the
# artifact's directory, concatenates their contents, and outputs a 7-char
# short MD5 hash (git-SHA-ish style).
#
# Exit codes:
#   0 â€” success (or match for --check, or clean scan, or --scan --update all ok)
#   1 â€” usage error, missing inputs, or --scan --update had failures
#   2 â€” mismatch (--check) or --scan found stale files (report mode)

set -euo pipefail

die() { echo "compute-input-hash: $*" >&2; exit 1; }

usage() {
  echo "Usage: compute-input-hash <artifact-file> [--update|--check]"
  echo "       compute-input-hash --scan <root-dir> [--update]"
  echo ""
  echo "Per-file commands:"
  echo "  (default)   Print the computed hash to stdout"
  echo "  --update    Compute and write the hash into the file's input-hash frontmatter"
  echo "  --check     Compare stored input-hash against computed; exit 2 on mismatch"
  echo ""
  echo "Scan commands:"
  echo "  --scan <dir>           Walk dir, report drift summary"
  echo "  --scan <dir> --update  Walk dir + update all stale hashes"
  exit 1
}

[[ $# -lt 1 ]] && usage

# === --scan mode: batch walk a directory and report/fix drift ===

if [[ "$1" == "--scan" ]]; then
  [[ $# -lt 2 ]] && die "--scan requires a directory argument"
  ROOT="$2"
  SCAN_MODE="${3:-report}"
  [[ ! -d "$ROOT" ]] && die "directory not found: $ROOT"

  SELF="$0"
  if [[ ! -x "$SELF" ]]; then
    SELF=$(command -v "$0" 2>/dev/null || true)
    [[ -z "$SELF" ]] && die "cannot resolve self for recursive invocation"
  fi

  TOTAL=0 MATCH=0 STALE=0 UNCOMPUTED=0 NOINPUT=0 UPDATED=0 UPDATE_FAILED=0

  while IFS= read -r f; do
    fname=$(basename "$f")
    case "$fname" in
      INDEX.md|*-INDEX.md|*-index.md) continue ;;
    esac

    TOTAL=$((TOTAL + 1))

    if OUT=$("$SELF" "$f" --check 2>&1); then CHECK_EC=0; else CHECK_EC=$?; fi

    if [[ "$CHECK_EC" -eq 0 ]]; then
      if echo "$OUT" | grep -q "no input-hash\|not yet computed"; then
        UNCOMPUTED=$((UNCOMPUTED + 1))
        [[ "$SCAN_MODE" == "report" ]] && echo "  UNCOMPUTED: $f" >&2
      elif echo "$OUT" | grep -q "no input files found\|no inputs:\|skipping"; then
        NOINPUT=$((NOINPUT + 1))
      else
        MATCH=$((MATCH + 1))
      fi
    elif [[ "$CHECK_EC" -eq 2 ]]; then
      STALE=$((STALE + 1))
      if [[ "$SCAN_MODE" == "--update" ]]; then
        if FIX_OUT=$("$SELF" "$f" --update 2>&1); then
          UPDATED=$((UPDATED + 1))
        else
          UPDATE_FAILED=$((UPDATE_FAILED + 1))
          echo "  UPDATE_FAILED: $f â€” $FIX_OUT" >&2
        fi
      else
        echo "  STALE: $f" >&2
      fi
    else
      NOINPUT=$((NOINPUT + 1))
    fi
  done < <(grep -rlE "^input-hash:" "$ROOT" --include="*.md" 2>/dev/null || true)

  echo "TOTAL=$TOTAL MATCH=$MATCH STALE=$STALE UNCOMPUTED=$UNCOMPUTED NOINPUT=$NOINPUT UPDATED=$UPDATED UPDATE_FAILED=$UPDATE_FAILED"

  if [[ "$SCAN_MODE" == "--update" ]]; then
    [[ "$UPDATE_FAILED" -gt 0 ]] && exit 1
    exit 0
  else
    [[ "$STALE" -gt 0 ]] && exit 2
    exit 0
  fi
fi

# === Per-file mode (existing behavior) ===

FILE="$1"
MODE="${2:-print}"
[[ ! -f "$FILE" ]] && die "file not found: $FILE"

# --- Extract inputs: from frontmatter ---
# Handles both inline array [file1, file2] and multi-line - file1 forms
INPUTS=$(awk '
  /^---$/{ fm++; next }
  fm==1 && /^inputs:/ {
    if (/\[/) {
      # Inline: inputs: [file1.md, file2.md]
      gsub(/.*\[/, "")
      gsub(/\].*/, "")
      gsub(/,/, "\n")
      gsub(/["'"'"' \t]/, "")
      print
    }
    in_arr=1
    next
  }
  fm==1 && in_arr && /^  *- / {
    sub(/^  *- */, "")
    gsub(/["'"'"' \t]/, "")
    print
  }
  fm==1 && in_arr && /^[^ -]/ { exit }
' "$FILE" | grep -v '^$' || true)

if [[ -z "$INPUTS" ]]; then
  if [[ "$MODE" == "--check" ]]; then
    echo "compute-input-hash: no inputs: field in $FILE â€” skipping" >&2
    exit 0
  fi
  die "no inputs: field found in frontmatter of $FILE"
fi

# --- Resolve file paths relative to artifact's parent directory ---
ARTIFACT_DIR=$(dirname "$FILE")

# For .factory/ artifacts, resolve paths relative to the .factory/ root
# e.g., if FILE is .factory/specs/prd.md with inputs: [domain-spec/L2-INDEX.md]
#        resolve to .factory/specs/domain-spec/L2-INDEX.md
# Also try .factory/ root for absolute-ish paths like architecture/ARCH-INDEX.md
FACTORY_ROOT=""
case "$FILE" in
  *.factory/*) FACTORY_ROOT="${FILE%%/.factory/*}/.factory" ;;
esac

CONCAT=""
MISSING=0
while IFS= read -r input_file; do
  [[ -z "$input_file" ]] && continue

  # Try paths in order: relative to artifact, parent dir, specs/, stories/,
  # phase-0-ingestion/, holdout-scenarios/, .factory/ root
  RESOLVED=""
  for base in "$ARTIFACT_DIR" "$ARTIFACT_DIR/.." \
    "${FACTORY_ROOT:+$FACTORY_ROOT/specs}" \
    "${FACTORY_ROOT:+$FACTORY_ROOT/stories}" \
    "${FACTORY_ROOT:+$FACTORY_ROOT/phase-0-ingestion}" \
    "${FACTORY_ROOT:+$FACTORY_ROOT/holdout-scenarios}" \
    "$FACTORY_ROOT"; do
    [[ -z "$base" ]] && continue
    if [[ -f "$base/$input_file" ]]; then
      RESOLVED="$base/$input_file"
      break
    fi
  done

  if [[ -z "$RESOLVED" ]]; then
    # Input file doesn't exist â€” skip it (may not be produced yet)
    MISSING=$((MISSING + 1))
    continue
  fi

  CONCAT="${CONCAT}$(cat "$RESOLVED")"
done <<< "$INPUTS"

if [[ -z "$CONCAT" ]]; then
  if [[ "$MODE" == "--check" ]]; then
    echo "compute-input-hash: no input files found for $FILE â€” skipping" >&2
    exit 0
  fi
  die "none of the input files exist: $INPUTS"
fi

# --- Compute short MD5 hash (7 chars) ---
if command -v md5sum &>/dev/null; then
  HASH=$(echo -n "$CONCAT" | md5sum | cut -c1-7)
elif command -v md5 &>/dev/null; then
  # macOS
  HASH=$(echo -n "$CONCAT" | md5 | cut -c1-7)
else
  die "neither md5sum nor md5 available"
fi

# --- Execute mode ---
case "$MODE" in
  print|--print)
    echo "$HASH"
    if [[ "$MISSING" -gt 0 ]]; then
      echo "compute-input-hash: warning: $MISSING input file(s) not found (may not be produced yet)" >&2
    fi
    ;;

  --update)
    # Read current input-hash value
    CURRENT=$(awk '
      /^---$/{ fm++; next }
      fm==1 && /^input-hash:/ {
        sub(/^input-hash:[ \t]*/, "")
        gsub(/["'"'"']/, "")
        print
        exit
      }
    ' "$FILE")

    if [[ "$CURRENT" == "$HASH" ]]; then
      echo "compute-input-hash: $FILE input-hash already current ($HASH)" >&2
      exit 0
    fi

    # Update the frontmatter in place
    if [[ -z "$CURRENT" ]] || [[ "$CURRENT" == "[md5]" ]] || [[ "$CURRENT" == "null" ]]; then
      # Field exists with placeholder â€” replace
      sed -i.bak "s/^input-hash:.*/input-hash: \"$HASH\"/" "$FILE"
    else
      # Field exists with old hash â€” replace
      sed -i.bak "s/^input-hash:.*/input-hash: \"$HASH\"/" "$FILE"
    fi
    rm -f "${FILE}.bak"
    echo "$HASH"
    echo "compute-input-hash: updated $FILE input-hash â†’ $HASH" >&2
    ;;

  --check)
    STORED=$(awk '
      /^---$/{ fm++; next }
      fm==1 && /^input-hash:/ {
        sub(/^input-hash:[ \t]*/, "")
        gsub(/["'"'"']/, "")
        print
        exit
      }
    ' "$FILE")

    if [[ -z "$STORED" ]] || [[ "$STORED" == "[md5]" ]] || [[ "$STORED" == "null" ]]; then
      echo "compute-input-hash: $FILE has no input-hash (not yet computed)" >&2
      exit 0
    fi

    if [[ "$STORED" == "$HASH" ]]; then
      exit 0
    else
      echo "compute-input-hash: DRIFT â€” $FILE input-hash $STORED â‰  computed $HASH" >&2
      echo "  Inputs may have changed since this artifact was produced." >&2
      exit 2
    fi
    ;;

  *)
    usage
    ;;
esac
