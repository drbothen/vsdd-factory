    {
      "id": 8,
      "title": "Token usage by type",
      "description": "Total tokens in the range, broken down by type (input, output, cacheRead, cacheCreation). Reveals where tokens are being spent — heavy cacheCreation one day often leads to heavy cacheRead on following days.",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
