{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Total subagent dispatches",
      "description": "Count of agent.start events in the selected range, across all subagent types.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.start\"} [$__range]))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Unique subagent types",
      "description": "Distinct subagent names that were dispatched at least once in the range. Reveals whether the factory is using its full agent catalogue or leaning heavily on a few.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "count(count by (attributes_subagent) (count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.start\"} | json | attributes_subagent != \"\" [$__range])))"
        }
      ]
    },
    {
      "id": 3,
      "title": "Successful stops",
      "description": "Count of agent.stop events with exit_class=ok. Successful subagent completions.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "0",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.stop\"} | json | attributes_exit_class = \"ok\" [$__range]))"
        }
      ]
    },
    {
      "id": 4,
      "title": "Non-ok stops",
      "description": "agent.stop events where exit_class is not `ok` — includes `empty` (subagent produced no result text) and `blocked` (subagent stopped due to a guard). High counts warrant investigation.",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.stop\"} | json | attributes_exit_class != \"ok\" | attributes_exit_class != \"\" [$__range]))"
        }
      ]
    },
    {
      "id": 5,
      "title": "Subagent invocation count",
      "description": "Top 15 subagent types ranked by dispatch count in the range. Carrier load — answers 'which subagent is doing most of the work today?'",
      "type": "bargauge",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "displayName": "${__field.labels.attributes_subagent}"
        }
      },
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(15, sum by (attributes_subagent) (count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.start\"} | json | attributes_subagent != \"\" [$__range])))",
          "legendFormat": "{{attributes_subagent}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Exit-class distribution (by subagent)",
      "description": "For each subagent type, the stacked count of ok / empty / blocked exits. Subagents with persistent empty or blocked exits are candidates for investigation.",
      "type": "barchart",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "orientation": "horizontal",
        "stacking": "normal",
        "xTickLabelRotation": 0,
        "legend": { "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (attributes_subagent, attributes_exit_class) (count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.stop\"} | json | attributes_subagent != \"\" | attributes_exit_class != \"\" [$__range]))",
          "legendFormat": "{{attributes_subagent}} — {{attributes_exit_class}}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Dispatches over time (by subagent)",
      "description": "Rate of agent.start events split by subagent type. Stacked bars highlight bursty vs. steady usage patterns per subagent.",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 1,
            "stacking": { "mode": "normal", "group": "A" }
          }
        }
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom", "showLegend": true }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (attributes_subagent) (count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.start\"} | json | attributes_subagent != \"\" [$__interval]))",
          "legendFormat": "{{attributes_subagent}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Recent subagent events",
      "description": "Log feed of agent.start and agent.stop events. Useful when tracing why a specific subagent misbehaved.",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service_name=\"vsdd-factory\",event_type=~\"agent.start|agent.stop\"}",
          "maxLines": 100
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["vsdd-factory", "subagents", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now/d", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Factory Subagents — Usage & Exit Classes",
  "uid": "factory-subagents",
  "version": 1,
  "weekStart": ""
}
