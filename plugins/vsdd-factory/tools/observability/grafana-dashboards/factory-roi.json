    {
      "id": 5,
      "title": "Cost per PR merged",
      "description": "Cross-datasource divide via Grafana server-side expression: A = sum(cost) from Prometheus, B = sum(pr.merged count) from Loki, C = $A / $B.",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range]))",
          "instant": true,
          "hide": false
        },
        {
          "refId": "B",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(count_over_time({service_name=\"vsdd-factory\",event_type=\"pr.merged\"}[$__range]))",
          "queryType": "instant",
          "hide": false
        },
        {
          "refId": "C",
          "datasource": {
            "type": "__expr__",
            "uid": "__expr__"
          },
          "type": "math",
          "expression": "$A / $B",
          "hide": false
        }
      ],
      "transformations": [
        {
          "id": "filterByRefId",
          "options": {
            "include": "C"
          }
        }
      ],
