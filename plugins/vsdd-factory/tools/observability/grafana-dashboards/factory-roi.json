    {
      "id": 10,
      "title": "Cost by query source",
      "description": "Cost split by claude_code.cost.usage.query_source attribute: main (your direct prompts), subagent (Task-tool dispatches), auxiliary (Claude's background work). Tells you where spend actually goes — often subagents dominate on a factory day.",
      "type": "piechart",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "unit": "currencyUSD",
          "decimals": 4
        }
      },
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (query_source) (increase(claude_code_cost_usage_USD_total[$__range]))",
          "legendFormat": "{{query_source}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Subagent dispatch efficiency",
      "description": "Agent dispatches per subagent type in the range. Read alongside cost-by-query-source to understand where subagent spend goes. Most-invoked subagents are rarely the most expensive — long-running subagents tend to dominate cost even with few dispatches.",
      "type": "bargauge",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 20
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "displayName": "${__field.labels.attributes_subagent}"
        }
      },
      "options": {
        "displayMode": "lcd",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "topk(10, sum by (attributes_subagent) (count_over_time({service_name=\"vsdd-factory\",event_type=\"agent.start\"} | json | attributes_subagent != \"\" [$__range])))",
          "legendFormat": "{{attributes_subagent}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Cost per active hour",
      "description": "Extrapolated from Claude SDK's `claude_code_active_time_seconds_total` counter, which measures **sustained compute time only** (streaming-response + tool-execution windows), NOT wall-clock session engagement. Typical sessions accumulate only seconds to a few minutes of active time. The headline number is therefore the **sustained-compute rate** — what an hour of uninterrupted Claude work would cost if extrapolated from the rate observed in the range — not an actual hourly spend. Useful as a stable cost-per-compute signal; complements Cost per PR / Cost per commit, which measure cost per output unit.",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "h": 4,
        "w": 8,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(increase(claude_code_cost_usage_USD_total[$__range])) / (sum(increase(claude_code_active_time_seconds_total[$__range])) / 3600)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "noValue": "N/A",
          "unit": "currencyUSD",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true,
        "justifyMode": "auto"
      },
      "pluginVersion": "13.0.1"
    },
